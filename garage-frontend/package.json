{
  "name": "garage-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 8080",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-api": "openapi-generator-cli generate -i ../garage-backend/openapi/garage-api.yaml -g javascript -o src/api/generated --additional-properties=useES6=true,npmName=garage-api",
    "prepare": "npm run generate-api",
    "clean": "rm -rf src/api/generated",
    "predev": "npm run generate-api",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "superagent": "^10.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@openapitools/openapi-generator-cli": "^2.31.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
