{
  "title": "Garage — System & garage_app",
  "uid": "backend-hpa",
  "tags": [
    "garage",
    "lab3"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(kube_pod_info, namespace)",
        "query": {
          "query": "label_values(kube_pod_info, namespace)",
          "refId": "ns"
        },
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1,
        "current": {
          "text": "garage-app",
          "value": "garage-app"
        }
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(kube_pod_info{namespace=\"$namespace\"}, pod)",
        "query": {
          "query": "label_values(kube_pod_info{namespace=\"$namespace\"}, pod)",
          "refId": "pod"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "System — системные ресурсы (узел и поды)",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 1,
      "title": "CPU узла, %",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 7
      },
      "description": "Суммарная загрузка CPU узла minikube (node-exporter).",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m]))) * 100",
          "legendFormat": "node CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Память узла, %",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 12,
        "h": 7
      },
      "description": "Использование памяти узла.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "node mem %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "CPU по подам (cores)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "description": "Нагрузка по CPU на каждый под выбранного namespace.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", pod=~\"$pod\"}[1m]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Память по подам (working set)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "description": "Память, используемая каждым подом.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"$namespace\", pod=~\"$pod\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": []
      }
    },
    {
      "id": 101,
      "title": "garage_app — JVM",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 5,
      "title": "JVM heap used по подам",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 12,
        "h": 7
      },
      "description": "Используемый размер heap JVM на каждом backend-поде.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (pod) (jvm_memory_used_bytes{application=\"garage-backend\", area=\"heap\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "JVM heap committed / max",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 17,
        "w": 12,
        "h": 7
      },
      "description": "Выделенный и максимальный размер heap.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (pod) (jvm_memory_committed_bytes{application=\"garage-backend\", area=\"heap\"})",
          "legendFormat": "committed {{pod}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (pod) (jvm_memory_max_bytes{application=\"garage-backend\", area=\"heap\"})",
          "legendFormat": "max {{pod}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "JVM live threads по подам",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 6
      },
      "description": "Число живых потоков JVM.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (pod) (jvm_threads_live_threads{application=\"garage-backend\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "GC: время пауз (rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 6
      },
      "description": "Совокупное время пауз GC в секунду.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (pod) (rate(jvm_gc_pause_seconds_sum{application=\"garage-backend\"}[1m]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": []
      }
    },
    {
      "id": 102,
      "title": "garage_app — HTTP-эндпоинты",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 9,
      "title": "RPS по эндпоинтам",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 12,
        "h": 8
      },
      "description": "Количество запросов в секунду по каждому эндпоинту.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{application=\"garage-backend\"}[1m]))",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "RPS по подам и эндпоинтам",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 31,
        "w": 12,
        "h": 8
      },
      "description": "Какие запросы и куда идут на каждом backend-поде.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (pod, uri) (rate(http_server_requests_seconds_count{application=\"garage-backend\"}[1m]))",
          "legendFormat": "{{pod}} {{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "title": "Время ответа — перцентили (все эндпоинты)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 39,
        "w": 12,
        "h": 8
      },
      "description": "Перцентили времени ответа (histogram-бакеты Micrometer) + наблюдаемый максимум.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.90, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"garage-backend\"}[5m])))",
          "legendFormat": "p90",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"garage-backend\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"garage-backend\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max(http_server_requests_seconds_max{application=\"garage-backend\"})",
          "legendFormat": "max (p100)",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "title": "p99 времени ответа по эндпоинтам",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 39,
        "w": 12,
        "h": 8
      },
      "description": "99-й перцентиль времени ответа в разрезе эндпоинтов.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum by (le, uri) (rate(http_server_requests_seconds_bucket{application=\"garage-backend\"}[5m])))",
          "legendFormat": "p99 {{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": []
      }
    },
    {
      "id": 103,
      "title": "garage_app — автомасштабирование (HPA, порог 15% CPU)",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 53,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 14,
      "title": "Реплики backend (HPA)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 54,
        "w": 12,
        "h": 8
      },
      "description": "Текущее/желаемое/min/max число реплик backend.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{horizontalpodautoscaler=\"backend-hpa\"}",
          "legendFormat": "current",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas{horizontalpodautoscaler=\"backend-hpa\"}",
          "legendFormat": "desired",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "kube_horizontalpodautoscaler_spec_min_replicas{horizontalpodautoscaler=\"backend-hpa\"}",
          "legendFormat": "min",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "kube_horizontalpodautoscaler_spec_max_replicas{horizontalpodautoscaler=\"backend-hpa\"}",
          "legendFormat": "max",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": []
      }
    },
    {
      "id": 15,
      "title": "CPU-утилизация backend vs порог 15%",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 54,
        "w": 12,
        "h": 8
      },
      "description": "CPU каждого backend-пода в % от request (200m). HPA масштабирует при среднем > 15%.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"garage-app\", pod=~\"backend-.*\"}[1m])) / 0.2 * 100",
          "legendFormat": "{{pod}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "vector(15)",
          "legendFormat": "порог 15%",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "порог 15%"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    10,
                    10
                  ],
                  "fill": "dash"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      }
    }
  ]
}